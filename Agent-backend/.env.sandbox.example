NODE_ENV=sandbox
PORT=3000
HOST=0.0.0.0
API_PREFIX=api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Sandbox providers
LLM_PROVIDER=deepseek
TTS_PROVIDER=mock
STT_PROVIDER=mock
PAYMENT_PROVIDER=mock
EMAIL_PROVIDER=mock
CACHE_DRIVER=memory
DATABASE_MODE=mock

# Real provider keys remain empty in sandbox
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_MODEL_ID=eleven_v3
ELEVENLABS_DEFAULT_OUTPUT_FORMAT=mp3_44100_128

# Admin sandbox account
ADMIN_EMAIL=admin@jarvis.local
ADMIN_PASSWORD=admin123456
ADMIN_PASSWORD_HASH=
ADMIN_TOKEN_ADJUST_MAX_AMOUNT=100000

# Billing
AGENT_TOKENS_PER_RMB=1000
BILLING_MULTIPLIER=1.5
TEXT_CHAT_MIN_BALANCE_AGENT_TOKENS=100
VOICE_CHAT_MIN_BALANCE_AGENT_TOKENS=1000
VOICE_REPLY_MAX_CHARS=200
DEEPSEEK_INPUT_CACHE_HIT_RMB_PER_MILLION=0.02
DEEPSEEK_INPUT_CACHE_MISS_RMB_PER_MILLION=1
DEEPSEEK_OUTPUT_RMB_PER_MILLION=2
ELEVENLABS_TTS_RMB_PER_100K_CHARS=35
USER_REGISTER_INITIAL_TOKENS=10000
BILLING_MODE=ENFORCE

# Temp audio
TEMP_AUDIO_DIR=/tmp/jarvis/audio
TEMP_AUDIO_TTL_SECONDS=600
