# App
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL="mysql://jarvis:jarvis_password@localhost:3306/jarvis"
PRISMA_LOG_LEVEL=query,error,warn

# Auth
JWT_SECRET=replace-with-local-dev-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
DEVICE_TOKEN_SECRET=replace-with-device-secret

# V1 Admin: single backend-defined admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash

# V1 Email verification code
AUTH_EMAIL_CODE_TTL_SECONDS=300
AUTH_EMAIL_CODE_RESEND_COOLDOWN_SECONDS=60
AUTH_EMAIL_CODE_MAX_ATTEMPTS=5
AUTH_EMAIL_CODE_MOCK_ENABLED=true
AUTH_EMAIL_CODE_MOCK_VALUE=123456

# Email provider
MAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Jarvis <no-reply@example.com>

# Cache
CACHE_DRIVER=memory
REDIS_URL=redis://localhost:6379
REDIS_NAMESPACE=jarvis:dev

# AI
LLM_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Voice
TTS_PROVIDER=mock
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_DEFAULT_MODEL_ID=eleven_v3
ELEVENLABS_DEFAULT_OUTPUT_FORMAT=mp3_44100_128
STT_PROVIDER=mock
STT_LANGUAGE=zh-CN

# Device
DEVICE_GATEWAY_DRIVER=mock
DEVICE_WS_PATH=/devices/ws
DEVICE_HEARTBEAT_SECONDS=30

# Robot
ROBOT_TRANSPORT_DRIVER=mock
ROBOT_COMMAND_TIMEOUT_MS=5000
ROBOT_MAX_MOVE_DISTANCE_CM=100
ROBOT_MAX_SPEED_LEVEL=LOW

# Observability
LOG_LEVEL=debug
REQUEST_LOGGING_ENABLED=true
TRACE_ID_HEADER=x-trace-id

# Billing
BILLING_MODE=TRACK_ONLY
INITIAL_USER_BALANCE_TOKENS=100000

# Temp Audio
TEMP_AUDIO_DRIVER=local
TEMP_AUDIO_DIR=/tmp/jarvis/audio
TEMP_AUDIO_TTL_SECONDS=600
TEMP_AUDIO_MAX_SIZE_MB=20

# Agent Tokens pricing (v1.5.8)
AGENT_TOKENS_PER_RMB=1000
BILLING_MULTIPLIER=1.5
TEXT_CHAT_MIN_BALANCE_AGENT_TOKENS=100
VOICE_CHAT_MIN_BALANCE_AGENT_TOKENS=1000
VOICE_REPLY_MAX_CHARS=200
DEEPSEEK_INPUT_CACHE_HIT_RMB_PER_MILLION=0.02
DEEPSEEK_INPUT_CACHE_MISS_RMB_PER_MILLION=1
DEEPSEEK_OUTPUT_RMB_PER_MILLION=2
ELEVENLABS_TTS_RMB_PER_100K_CHARS=35

# Recharge orders (v1.5.9)
RECHARGE_ORDER_TTL_SECONDS=900
RECHARGE_PAYMENT_PROVIDER=mock
RECHARGE_MOCK_PAY_ENABLED=true
RECHARGE_PACKAGES=5:5000,10:10000,30:30000,50:50000,100:100000
PAYMENT_WECHAT_ENABLED=false
PAYMENT_ALIPAY_ENABLED=false

# v1.5.10 Admin manual Agent Tokens adjustment
ADMIN_TOKEN_ADJUST_MAX_AMOUNT=100000

# v1.6 Mock API
MOCK_API_ENABLED=true
MOCK_USER_ID=user_mock_001
MOCK_AGENT_SESSION_ID=session_mock_jarvis
MOCK_TEXT_INPUT_TOKENS=1000
MOCK_TEXT_OUTPUT_TOKENS=200
MOCK_VOICE_TTS_CHARACTERS=18
